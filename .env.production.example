# Copy this file to .env on EC2.
# Do not commit real production secrets.

DOCKERHUB_USERNAME=your-dockerhub-user
IMAGE_TAG=latest

VITE_API_URL=/api
APP_FRONTEND_URL=http://your-ec2-public-ip
APP_TIME_ZONE=Europe/Stockholm
APP_INVOICE_REMINDERS_CRON=0 0 9 * * *

SPRING_DATASOURCE_URL=jdbc:postgresql://your-rds-endpoint.eu-north-1.rds.amazonaws.com:5432/cloudshop
SPRING_DATASOURCE_USERNAME=cloudshop
SPRING_DATASOURCE_PASSWORD=replace_with_rds_password

JWT_SECRET=replace_with_long_random_secret_at_least_32_chars

STRIPE_SECRET_KEY=sk_test_or_live_key
STRIPE_WEBHOOK_SECRET=whsec_from_stripe

SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=google-app-password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
